[Unit]
Description=Create encrypted-ready local MealHouse backup
After=postgresql.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/srv/mealhouse/scripts/backup.sh
Nice=10
IOSchedulingClass=idle
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/mealhouse/backups

