[Unit]
Description=Enqueue MealHouse scheduled jobs
After=postgresql.service

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/srv/mealhouse
EnvironmentFile=/etc/mealhouse/mealhouse.env
ExecStart=/srv/mealhouse/.venv/bin/python manage.py schedulejobs
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

